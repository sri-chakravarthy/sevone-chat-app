# Remote MCP Server Configuration for Bob
SEVONE_MCP_URL=https://unix-host.example.com:8443/sse
SEVONE_MCP_AUTH_TOKEN=replace_with_secure_token

# Database Execution Configuration
# Use tcp when sevone-mysql-mcp runs as a container and reaches MySQL through the host listener.
# Use podman_exec only when the MCP runtime can directly execute podman against the target container context.
DB_ACCESS_MODE=tcp

# TCP mode settings
MYSQL_HOST=c49988v1.fyre.ibm.com
MYSQL_PORT=3306
MYSQL_DATABASE=net
MYSQL_USER=root
MYSQL_PASSWORD=mcppassword

# Podman mode settings
PODMAN_BINARY=/usr/bin/podman
PODMAN_CONTAINER_NAME=nms-nms-nms
MYSQL_CLIENT_PATH=/usr/bin/mysql
MYSQL_DEFAULTS_FILE=

# Shared execution settings
DB_COMMAND_TIMEOUT=30
DB_MAX_CONCURRENT_COMMANDS=5

# Security Configuration
ALLOWED_OPERATIONS=SELECT,INSERT
MAX_QUERY_LENGTH=5000
QUERY_TIMEOUT=30
ENABLE_QUERY_LOGGING=true

# Application Configuration
LOG_LEVEL=INFO